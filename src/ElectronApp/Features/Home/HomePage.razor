@page "/"
@implements IDisposable
@inject Security.IExternalLinkService ExternalLinkService

<PageTitle>Home</PageTitle>

<h1 class="text-2xl font-bold tracking-tight">Electron-Blazor-Tailwind</h1>

<p class="mt-2 text-sm text-muted-foreground">
    Cross-platform desktop application template built on .NET 10
</p>

<div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-3">
    <div class="rounded-md border border-border p-4 transition-colors hover:bg-accent">
        <div class="flex items-center gap-2">
            <Blazicon Svg="Lucide.Monitor" class="size-4 text-muted-foreground"/>
            <span class="font-mono text-sm font-medium">Electron.NET</span>
        </div>
        <p class="mt-2 text-xs text-muted-foreground leading-relaxed">
            Cross-platform desktop shell with secure window management and single-instance support
        </p>
    </div>
    <div class="rounded-md border border-border p-4 transition-colors hover:bg-accent">
        <div class="flex items-center gap-2">
            <Blazicon Svg="Lucide.Component" class="size-4 text-muted-foreground"/>
            <span class="font-mono text-sm font-medium">Blazor</span>
        </div>
        <p class="mt-2 text-xs text-muted-foreground leading-relaxed">
            Interactive UI with Fluxor state management, vertical slice architecture, and component testing
        </p>
    </div>
    <div class="rounded-md border border-border p-4 transition-colors hover:bg-accent">
        <div class="flex items-center gap-2">
            <Blazicon Svg="Lucide.Paintbrush" class="size-4 text-muted-foreground"/>
            <span class="font-mono text-sm font-medium">Tailwind CSS</span>
        </div>
        <p class="mt-2 text-xs text-muted-foreground leading-relaxed">
            Utility-first styling with dark mode, CSS variables, and design tokens
        </p>
    </div>
</div>

<h2 class="mt-8 text-sm font-semibold">Resources</h2>
<div class="mt-3 flex gap-3">
    <button type="button"
            @onclick="@(() => ExternalLinkService.TryOpenAsync(GithubUrl, _cts.Token))"
            class="cursor-pointer flex items-center gap-2 rounded-md border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
        <Blazicon Svg="Lucide.Github" class="size-4"/>
        Author
    </button>
    <button type="button"
            @onclick="@(() => ExternalLinkService.TryOpenAsync(ElectronNetUrl, _cts.Token))"
            class="cursor-pointer flex items-center gap-2 rounded-md border border-border px-4 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
        <Blazicon Svg="Lucide.ExternalLink" class="size-4"/>
        Electron.NET
    </button>
</div>

@code
{
    private const string GithubUrl = "https://github.com/thomas-fazzari";
    private const string ElectronNetUrl = "https://github.com/ElectronNET/Electron.NET";

    private readonly CancellationTokenSource _cts = new();

    public void Dispose() { _cts.Cancel(); _cts.Dispose(); }
}
